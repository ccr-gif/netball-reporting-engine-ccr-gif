// src/storage/repository.ts
import { run, all, get, initDb } from './db';

export type EventType =
  | 'shot_made' | 'shot_miss'
  | 'feed' | 'assist'
  | 'rebound_off' | 'rebound_def'
  | 'centerpass_receive'
  | 'penalty'
  | 'turnover_won' | 'turnover_lost'
  | 'interception'
  | 'bad_pass'

  // ✅ Dynamic custom stats (player + team)
  | 'custom'

  // 🔹 Team flow stats
  | 'cp_to_score' | 'cp_no_score' | 'to_to_score';

export function cryptoId() {
  return Math.random().toString(36).slice(2) + Date.now().toString(36);
}

/* ========= PLAYERS ========= */

export async function addPlayer(p: {
  id?: string;
  first_name: string;
  last_name: string;
  positions?: string[];
  notes?: string | null;          // store { photo_uri } JSON here
}) {
  await initDb();
  const id = p.id ?? cryptoId();
  const positions = p.positions ? JSON.stringify(p.positions) : '[]';
  await run(
    `insert into player (id, team_id, first_name, last_name, positions, notes)
     values (?,?,?,?,?,?)`,
    [id, null, (p.first_name ?? '').trim(), (p.last_name ?? '').trim(), positions, p.notes ?? null]
  );
  return id;
}

export async function updatePlayer(p: {
  id: string;
  first_name?: string;
  last_name?: string;
  positions?: string[] | null;
  notes?: string | null;
}) {
  await initDb();
  const current: any = await get(`select * from player where id=?`, [p.id]);
  if (!current) throw new Error('Player not found');

  const nextFirst = (p.first_name ?? current.first_name ?? '').trim();
  const nextLast  = (p.last_name ?? current.last_name ?? '').trim();
  const nextPos   = p.positions ? JSON.stringify(p.positions) : (current.positions ?? '[]');
  const nextNotes = p.notes ?? current.notes ?? null;

  await run(
    `update player set first_name=?, last_name=?, positions=?, notes=? where id=?`,
    [nextFirst, nextLast, nextPos, nextNotes, p.id]
  );
}

export async function listPlayers() {
  await initDb();
  const rows: any[] = await all(`select * from player order by last_name, first_name`);
  return (rows || []).map(r => {
    const positions = r.positions ? JSON.parse(r.positions) : [];
    let photo_uri: string | null = null;
    try {
      if (r.notes) {
        const j = JSON.parse(r.notes);
        photo_uri = j?.photo_uri ?? null;
      }
    } catch {}
    return { ...r, positions, photo_uri };
  });
}

export async function getPlayersMap() {
  const rows: any[] = await all(`select id, first_name, last_name from player`);
  const map: Record<string, { id: string; name: string }> = {};
  for (const r of rows) map[r.id] = { id: r.id, name: `${r.first_name || ''} ${r.last_name || ''}`.trim() };
  return map;
}

/** Returns counts of dependent rows referencing this player. */
export async function countPlayerUsage(playerId: string) {
  await initDb();
  const events: any = await get(`select count(*) as c from event where player_id=?`, [playerId]);
  const lineupRefs: any = await get(`select count(*) as c from lineup_player where player_id=?`, [playerId]);
  return { events: events?.c ?? 0, lineupRefs: lineupRefs?.c ?? 0 };
}

/**
 * Delete player. If hard=true, also removes event + lineup_player references to prevent
 * orphan records. If hard=false and there is usage, throws an error.
 */
export async function deletePlayer(playerId: string, opts: { hard?: boolean } = {}) {
  await initDb();
  const { events, lineupRefs } = await countPlayerUsage(playerId);
  if (!opts.hard && (events > 0 || lineupRefs > 0)) {
    throw new Error(`Player has usage (events: ${events}, lineup refs: ${lineupRefs}). Use hard delete.`);
  }
  if (opts.hard) {
    await run(`delete from event where player_id=?`, [playerId]);
    await run(`delete from lineup_player where player_id=?`, [playerId]);
  }
  await run(`delete from player where id=?`, [playerId]);
}

/* ========= EVENTS ========= */

export async function addCustomStatEvent(params: {
  match_id: string;
  period_id: string;
  stat_id: string;                 // e.g. 'drop_ball', 'step', 'contact', etc.
  scope: 'player' | 'team';

  // Required only if scope === 'player'
  player_id?: string;
  position_at_time?: string;
}) {
  await initDb();

  if (params.scope === 'player') {
    if (!params.player_id || !params.position_at_time) {
      throw new Error('Player custom stat requires player_id and position_at_time');
    }
  }

  await run(
    `
    insert into event (
      id,
      match_id,
      period_id,
      player_id,
      type,
      position_at_time,
      ts,
      meta
    ) values (?,?,?,?,?,?,?,?)
    `,
    [
      cryptoId(),
      params.match_id,
      params.period_id,
      params.scope === 'player' ? params.player_id : null,
      'custom',
      params.scope === 'player' ? params.position_at_time : null,
      new Date().toISOString(),
      JSON.stringify({
        stat_id: params.stat_id,
        scope: params.scope,
      }),
    ]
  );
}


export async function addEvent(ev: {
  id: string; match_id: string; period_id: string;
  player_id: string; type: EventType;
  position_at_time?: string; x?: number; y?: number;
