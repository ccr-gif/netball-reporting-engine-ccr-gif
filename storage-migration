export async function getLastEventForPositionQuarter(
  matchId: string,
  quarterNumber: number,
  position: string
) {
  await initDb();
  const periodId = 'Q' + quarterNumber;
  const row: any = await get(
    
`select id, type
       from event
      where match_id=?           -- ✅ HERE
        and period_id=?         -- ✅ HERE
        and position_at_time=?  -- ✅ HERE
		and type != 'custom'
      order by datetime(ts) desc, rowid desc
      limit 1`,
    [matchId, periodId, position]

  );
  return row || null;
}

export async function deleteEventById(id: string) {
  await initDb();
  await run(`delete from event where id=?`, [id]);
}

export async function decHomeSafe(matchId: string, quarterNumber: number) {
  await initDb();
  const cur: any = await get(
    `select coalesce(home_score,0) as h
       from period
      where match_id=? and number=?`,
    [matchId, quarterNumber]
  );
  const newH = Math.max(0, (cur?.h ?? 0) - 1);
  await run(
    `update period set home_score=? where match_id=? and number=?`,
    [newH, matchId, quarterNumber]
  );
}


export async function updateStatsForPositionStint(matchId: string, row: any) {
  await initDb();

  // ✅ Delete ALL existing events for this stint
  await run(
    `
    delete from event
    where match_id=?
      and period_id=?
      and player_id=?
      and position_at_time=?
    `,
    [
      matchId,
      row.period_id,
      row.player_id,
      row.position,
    ]
  );

  const add = async (type: string, count: number) => {
    for (let i = 0; i < (count || 0); i++) {
      await run(
        `insert into event (
          id, match_id, period_id, player_id, type, position_at_time, ts
        ) values (?,?,?,?,?,?,?)`,
        [
          cryptoId(),
          matchId,
          row.period_id,
          row.player_id,
          type,
          row.position,
          new Date().toISOString()
        ]
      );
    }
  };

  // ✅ REBUILD events from edited values
  await add('shot_made', row.goals || 0);
  await add('shot_miss', (row.attempts || 0) - (row.goals || 0));
  await add('assist', row.assists || 0);
  await add('feed', row.feeds || 0);
  await add('rebound_off', row.rebound_off || 0);
  await add('rebound_def', row.rebound_def || 0);
  await add('centerpass_receive', row.cpr || 0);
  await add('penalty', row.penalties || 0);
  await add('turnover_won', row.to_won || 0);
  await add('turnover_lost', row.to_lost || 0);
  await add('interception', row.interceptions || 0);
  await add('bad_pass', row.bad_pass || 0);

  // ✅ CUSTOM STATS
  Object.keys(row)
    .filter(k => k.startsWith("custom:"))
    .forEach(async (key) => {
      await add(key, row[key] || 0);
    });
}
