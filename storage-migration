/**
 * 🔹 NEW: Team flow aggregates by quarter (Team summary row).
 * Counts the three team-flow event types regardless of player_id,
 * since these events are intended to be recorded on the Team tile.
 */
export async function getTeamFlowByQuarter(matchId: string) {
  await initDb();
  const rows: any[] = await all(
    `select period_id,
            sum(case when type='cp_to_score' then 1 else 0 end) as cp_to_score,
            sum(case when type='cp_no_score' then 1 else 0 end) as cp_no_score,
            sum(case when type='to_to_score' then 1 else 0 end) as to_to_score
       from event
      where match_id=?
        and type in ('cp_to_score','cp_no_score','to_to_score')
      group by period_id
      order by period_id asc`,
    [matchId]
  );

  // ✅ FIX — convert rows array to quarter map
  const out: Record<string, { cp_to_score: number; cp_no_score: number; to_to_score: number }> = {};

  for (const r of rows || []) {
    out[r.period_id] = {
      cp_to_score: r.cp_to_score || 0,
      cp_no_score: r.cp_no_score || 0,
      to_to_score: r.to_to_score || 0,
    };
  }

  return out;
}

