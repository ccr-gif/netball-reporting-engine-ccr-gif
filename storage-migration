/**
 * Player totals by quarter. We explicitly EXCLUDE team-flow event types so
 * they don't create a synthetic "__TEAM__" group or otherwise pollute counts.
 */
 
 /**
 * ✅ Aggregate stats for ONE POSITION STINT.
 * Stats are attributed ONLY while the player played that position.
 */
export async function getStatsForPositionStint(
  matchId: string,
  stint: PositionStint
) {
  await initDb();

  return get(
    `
    select
      sum(case when type in ('shot_made','shot_miss') then 1 else 0 end) as attempts,
      sum(case when type='shot_made' then 1 else 0 end) as goals,
      sum(case when type='assist' then 1 else 0 end) as assists,
      sum(case when type='feed' then 1 else 0 end) as feeds,
      sum(case when type='rebound_off' then 1 else 0 end) as rebound_off,
      sum(case when type='rebound_def' then 1 else 0 end) as rebound_def,
      sum(case when type='centerpass_receive' then 1 else 0 end) as cpr,
      sum(case when type='penalty' then 1 else 0 end) as penalties,
      sum(case when type='turnover_won' then 1 else 0 end) as to_won,
      sum(case when type='turnover_lost' then 1 else 0 end) as to_lost,
      sum(case when type='interception' then 1 else 0 end) as interceptions,
      sum(case when type='bad_pass' then 1 else 0 end) as bad_passes
    from event
    where match_id=?
      and period_id=?
      and player_id=?
      and position_at_time=?
      and ts >= ?
      and (? is null or ts < ?)
      
      and type in (
        'shot_made','shot_miss',
        'assist','feed',
        'rebound_off','rebound_def',
        'centerpass_receive',
        'penalty',
        'turnover_won','turnover_lost',
        'interception',
        'bad_pass'
      )

    `,
    [
      matchId,
      stint.period_id,
      stint.player_id,
      stint.position,
      stint.start_ts,
      stint.end_ts,
      stint.end_ts,
    ]
  );
}
 
 /**
 * ✅ Aggregate CUSTOM PLAYER stats for ONE POSITION STINT.
 * Dynamic: works for any custom stat_id.
 */

export async function getCustomPlayerStatsForStint(
  matchId: string,
  stint: PositionStint
): Promise<Record<string, number>> {
  await initDb();

  const rows: any[] = await all(
    `
    select
      type as stat_id,
      count(*) as c
    from event
    where match_id = ?
      and period_id = ?
      and player_id = ?
      and position_at_time = ?
      and type like 'custom:%'
      and ts >= ?
      and (? is null or ts < ?)
    group by type
    `,
    [
      matchId,
      stint.period_id,
      stint.player_id,
      stint.position,
      stint.start_ts,
      stint.end_ts,
      stint.end_ts,
    ]
  );
  
const out: Record<string, number> = {};
  for (const r of rows || []) {
    if (r?.stat_id) out[r.stat_id] = r.c;
  }
  return out;
}


