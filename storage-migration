/* ========= LINEUP ========= */

export type LineupMap = Record<string, string | null>;

export async function getLineup(matchId: string, periodLabel: string): Promise<LineupMap> {
  await initDb();
  const lu: any = await get(
    `select id from lineup where match_id=? and period_id=? order by started_at desc limit 1`,
    [matchId, periodLabel]
  );
  if (!lu) return {};
  const rows: any[] = await all(`select position, player_id from lineup_player where lineup_id=?`, [lu.id]);
  const map: LineupMap = {};
  for (const r of rows) map[r.position] = r.player_id;
  return map;
}

/**
 * ✅ NEW — Get ALL players who appeared in a quarter, across ALL lineup snapshots.
 * This ensures subs (e.g. GS-A then GS-B) BOTH appear in reports.
 *
 * Returns:
 * {
 *   GS: [playerA, playerB],
 *   GA: [playerC],
 *   ...
 * }
 */
export async function getAllLineupsForQuarter(
  matchId: string,
  periodLabel: string
): Promise<Record<string, string[]>> {
  await initDb();

  // Get all lineup snapshots for the quarter (oldest → newest)
  const lineups: any[] = await all(
    `select id
       from lineup
      where match_id=? and period_id=?
      order by started_at asc`,
    [matchId, periodLabel]
  );

  const seen = new Set<string>();
  const result: Record<string, string[]> = {};

  for (const lu of lineups) {
    const rows: any[] = await all(
      `select position, player_id
         from lineup_player
        where lineup_id=?`,
      [lu.id]
    );

    for (const r of rows) {
      if (!r.player_id) continue;

      if (!result[r.position]) {
        result[r.position] = [];
      }

      const key = `${r.position}|${r.player_id}`;
      if (!seen.has(key)) {
        seen.add(key);
        result[r.position].push(r.player_id);
      }
    }
  }

  return result;
}

/* ========= POSITION STINTS (REPORTING) ========= */

export type PositionStint = {
  period_id: string;      // e.g. 'Q3'
  position: string;       // 'GS', 'GA', etc
  player_id: string;
  start_ts: string;       // lineup.started_at
  end_ts: string | null;  // null = until quarter end
  index: number;          // 1, 2, 3… per position
};

/**
 * ✅ Build POSITION STINTS for a quarter.
 * A stint = one player playing one position until a sub changes it.
 *
 * Preserves re‑entries, order, and injuries.
 */
export async function getPositionStintsForQuarter(
  matchId: string,
  periodLabel: string
): Promise<PositionStint[]> {
  await initDb();

  // Get all lineup snapshots (oldest → newest)
  const lineups: any[] = await all(
    `select id, started_at
       from lineup
      where match_id=? and period_id=?
      order by started_at asc`,
    [matchId, periodLabel]
  );

  if (lineups.length === 0) return [];

  // Build snapshot maps
  const snapshots: { ts: string; map: Record<string, string> }[] = [];

  for (const l of lineups) {
    const rows: any[] = await all(
      `select position, player_id
         from lineup_player
        where lineup_id=?`,
      [l.id]
    );

    const map: Record<string, string> = {};
    for (const r of rows) {
      if (r.player_id) map[r.position] = r.player_id;
    }

    snapshots.push({ ts: l.started_at, map });
  }

  const stints: PositionStint[] = [];
  const active: Record<
  string,
  { player_id: string; start_ts: string; index: number }
> = {};

const positionCounters: Record<string, number> = {};

  // Walk snapshots in time order
  for (const snap of snapshots) {
    for (const position of Object.keys(snap.map)) {
      const pid = snap.map[position];

      // New stint if position empty or player changed
      if (!active[position] || active[position].player_id !== pid) {
        // Close previous
        if (active[position]) {
  stints.push({
    period_id: periodLabel,
    position,
    player_id: active[position].player_id,
    start_ts: active[position].start_ts,
    // ✅ CLOSE STRICTLY BEFORE NEXT STINT
    end_ts: new Date(new Date(snap.ts).getTime() - 1).toISOString(),
    index: active[position].index,
  });
}


        positionCounters[position] = (positionCounters[position] ?? 0) + 1;

        active[position] = {
           player_id: pid,
           start_ts: snap.ts,
           index: positionCounters[position],
         };
      }
    }
  }

  // Close final open stints
for (const position of Object.keys(active)) {
  stints.push({
    period_id: periodLabel,
    position,
    player_id: active[position].player_id,
    start_ts: active[position].start_ts,
    end_ts: null, // ✅ open until end of quarter
    index: active[position].index,
  });
}

  return stints;
}

export async function saveLineup(
  matchId: string,
  periodLabel: string,
  map: LineupMap,
  opts?: { replace?: boolean }   // ✅ NEW
) {
  await initDb();
  

  // ✅ REMOVE existing lineups ONLY when replacing
  if (opts?.replace) {
    const oldLineups: any[] = await all(
      `select id from lineup where match_id=? and period_id=?`,
      [matchId, periodLabel]
    );
	
	
// ✅ LOG B — what is being deleted
    console.log('🟣 saveLineup deleting old lineups', oldLineups.map(l => l.id));


    for (const lu of oldLineups) {
      await run(`delete from lineup_player where lineup_id=?`, [lu.id]);
      await run(`delete from lineup where id=?`, [lu.id]);
    }
  }

  // ✅ Always insert a new lineup snapshot
  const lid = cryptoId();
  const now = new Date().toISOString();

  await run(
    `insert into lineup (id, match_id, period_id, started_at)
     values (?,?,?,?)`,
    [lid, matchId, periodLabel, now]
  );

  for (const pos of Object.keys(map || {})) {
    const pid = map[pos];
    if (!pid) continue;
    await run(
      `insert into lineup_player (id, lineup_id, player_id, position)
       values (?,?,?,?)`,
      [cryptoId(), lid, pid, pos]
    );
  } 

return lid;

}


export async function copyLineupFromPreviousQuarter(matchId: string, currentQuarter: number) {
  await initDb();
  if (currentQuarter <= 1) return;
  const curr = await getLineup(matchId, 'Q' + currentQuarter);
  const hasAny = Object.values(curr || {}).some(Boolean);
  if (hasAny) return;
  const prev = await getLineup(matchId, 'Q' + (currentQuarter - 1));
  const prevHasAny = Object.values(prev || {}).some(Boolean);
  if (prevHasAny) await saveLineup(matchId, 'Q' + currentQuarter, prev);
}

/* ---- Carry starting lineup (Q1) from the most recent previous match ---- */

export async function getMostRecentOtherMatchId(currentMatchId: string) {
  await initDb();
  const row: any = await get(
    `select id
       from match
      where id <> ?
      order by (substr(match_date,7,4) || '-' || substr(match_date,4,2) || '-' || substr(match_date,1,2)) desc,
               rowid desc
      limit 1`,
    [currentMatchId]
  );
  return row?.id ?? null;
}

export async function copyStartingLineupFromPreviousMatch(
  currentMatchId: string,
  targetPeriodLabel: string = 'Q1'
) {
  await initDb();
  const curr = await getLineup(currentMatchId, targetPeriodLabel);
  if (Object.values(curr || {}).some(Boolean)) return;

  const prevId = await getMostRecentOtherMatchId(currentMatchId);
  if (!prevId) return;
  const prev = await getLineup(prevId, targetPeriodLabel);
  if (!Object.values(prev || {}).some(Boolean)) return;

  await saveLineup(currentMatchId, targetPeriodLabel, prev);
}

/* ========= PERIOD & SCORES ========= */

export async function ensurePeriod(matchId: string, number: number) {
  await initDb();
  const p = await get(`select id from period where match_id=? and number=?`, [matchId, number]);
  if (p?.id) return p.id as string;
  const id = cryptoId();
  await run(
    `insert into period (id, match_id, number, seconds_played, home_score, away_score)
     values (?,?,?,?,0,0)`,
    [id, matchId, number, 0]
  );
  return id;
}

export async function getPeriodScores(matchId: string, number: number) {
  await initDb();
  const p = await get(`select home_score, away_score from period where match_id=? and number=?`, [matchId, number]);
  return { home: p?.home_score || 0, away: p?.away_score || 0 };
}

export async function getCumulativeScores(matchId: string) {
  await initDb();
  const s: any = await get(
    `select coalesce(sum(home_score),0) as home, coalesce(sum(away_score),0) as away
       from period where match_id=?`,
    [matchId]
  );
  return { home: s?.home || 0, away: s?.away || 0 };
}

export async function incHome(matchId: string, number: number, by = 1) {
  await ensurePeriod(matchId, number);
  await run(
    `update period set home_score = coalesce(home_score,0) + ? where match_id=? and number=?`,
    [by, matchId, number]
  );
}

export async function incAway(matchId: string, number: number, by = 1) {
  await ensurePeriod(matchId, number);
  await run(
    `update period set away_score = coalesce(away_score,0) + ? where match_id=? and number=?`,
    [by, matchId, number]
  );
}

export async function setScores(matchId: string, number: number, home: number, away: number) {
  await ensurePeriod(matchId, number);
  await run(
    `update period set home_score=?, away_score=? where match_id=? and number=?`,
    [home, away, matchId, number]
  );
}

