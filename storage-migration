/**
 * Most-used position per player per quarter (mode).
 * Team-flow events (position_at_time='TEAM') won't affect player rows here;
 * if they exist, they would belong to a different "player_id" anyway.
 */
export async function getPositionModeByQuarter(matchId: string) {
  await initDb();
  const rows: any[] = await all(`
    select period_id, player_id, position_at_time as pos, count(*) as cnt
    from event
    where match_id=? and position_at_time is not null
    group by period_id, player_id, position_at_time
    order by period_id asc, player_id asc, cnt desc
  `, [matchId]);
  const map: Record<string, Record<string, string>> = {};
  for (const r of rows) {
    map[r.period_id] = map[r.period_id] || {};
    if (!map[r.period_id][r.player_id]) map[r.period_id][r.player_id] = r.pos;
  }
  return map;
}

